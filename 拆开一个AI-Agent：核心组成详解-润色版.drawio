  <diagram name="agent-loop-control" id="page-agent-loop-control">
    <mxGraphModel dx="1000" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0" background="#F7F9FC">
      <root>
        <mxCell id="p5-0"/><mxCell id="p5-1" parent="p5-0"/>
        <mxCell id="p5-title" value="Agent Loop 的继续、等待与停止" style="text;html=0;align=center;verticalAlign=middle;resizable=0;points=[];fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=20;fontStyle=1;fontColor=#2D3748;" vertex="1" parent="p5-1"><mxGeometry x="210" y="24" width="407" height="40" as="geometry"/></mxCell>
        <mxCell id="p5-read" value="读取目标和当前记忆" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#64748B;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="323" y="110" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="p5-llm" value="LLM 判断下一步" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="323" y="240" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="p5-decision" value="直接回答？" style="rhombus;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="348" y="370" width="130" height="90" as="geometry"/></mxCell>
        <mxCell id="p5-tool" value="调用工具" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#D9864F;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="110" y="520" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="p5-answer" value="生成最终结果" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#44978C;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="547" y="520" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="p5-memory" value="保存工具结果和任务状态" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#6F5CC2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="110" y="680" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="p5-condition" value="循环条件？" style="rhombus;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="348" y="670" width="130" height="90" as="geometry"/></mxCell>
        <mxCell id="p5-wait" value="等待用户参数&#xa;或人工确认" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#D9864F;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="110" y="860" width="190" height="70" as="geometry"/></mxCell>
        <mxCell id="p5-stop" value="停止并返回&#xa;结果或错误" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#44978C;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p5-1"><mxGeometry x="527" y="860" width="190" height="70" as="geometry"/></mxCell>
        <mxCell id="p5-guardrail" value="代码必须限制最大轮数、超时、费用、权限和连续失败" style="text;html=0;align=center;verticalAlign=middle;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#DC2626;" vertex="1" parent="p5-1"><mxGeometry x="180" y="1020" width="467" height="36" as="geometry"/></mxCell>
        <mxCell id="p5-e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="p5-read" target="p5-llm" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="p5-llm" target="p5-decision" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e3" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p5-decision" target="p5-tool" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e4" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p5-decision" target="p5-answer" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="p5-tool" target="p5-memory" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e6" value="检查" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p5-memory" target="p5-condition" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e7" value="继续" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="p5-condition" target="p5-llm" parent="p5-1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="770" y="715"/><mxPoint x="770" y="270"/></Array></mxGeometry></mxCell>
        <mxCell id="p5-e8" value="等待" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p5-condition" target="p5-wait" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e9" value="停止" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p5-condition" target="p5-stop" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p5-e10" value="完成" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p5-answer" target="p5-stop" parent="p5-1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="java-agent-architecture" id="page-java-agent-architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0" background="#F7F9FC">
      <root>
        <mxCell id="p6-0"/><mxCell id="p6-1" parent="p6-0"/>
        <mxCell id="p6-title" value="四个核心部分在 Java 后端中的落位" style="text;html=0;align=center;verticalAlign=middle;resizable=0;points=[];fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=20;fontStyle=1;fontColor=#2D3748;" vertex="1" parent="p6-1"><mxGeometry x="270" y="24" width="460" height="40" as="geometry"/></mxCell>
        <mxCell id="p6-group1" value="接入层" style="swimlane;whiteSpace=wrap;html=0;fillColor=none;strokeColor=#1889A2;dashed=1;strokeWidth=2;fontColor=#2D3748;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;" vertex="1" parent="p6-1"><mxGeometry x="30" y="120" width="180" height="450" as="geometry"/></mxCell>
        <mxCell id="p6-group2" value="调度层" style="swimlane;whiteSpace=wrap;html=0;fillColor=none;strokeColor=#0B6170;dashed=1;strokeWidth=2;fontColor=#2D3748;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;" vertex="1" parent="p6-1"><mxGeometry x="240" y="120" width="210" height="450" as="geometry"/></mxCell>
        <mxCell id="p6-group3" value="Agent 运行时组件" style="swimlane;whiteSpace=wrap;html=0;fillColor=none;strokeColor=#6F5CC2;dashed=1;strokeWidth=2;fontColor=#2D3748;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;" vertex="1" parent="p6-1"><mxGeometry x="480" y="90" width="260" height="510" as="geometry"/></mxCell>
        <mxCell id="p6-group4" value="原有后端能力" style="swimlane;whiteSpace=wrap;html=0;fillColor=none;strokeColor=#64748B;dashed=1;strokeWidth=2;fontColor=#2D3748;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;" vertex="1" parent="p6-1"><mxGeometry x="770" y="120" width="200" height="450" as="geometry"/></mxCell>
        <mxCell id="p6-controller" value="AgentController&#xa;接收任务" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#1889A2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="50" y="210" width="140" height="70" as="geometry"/></mxCell>
        <mxCell id="p6-service" value="AgentService&#xa;创建任务" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="50" y="370" width="140" height="70" as="geometry"/></mxCell>
        <mxCell id="p6-runner" value="AgentRunner&#xa;加载记忆&#xa;驱动每一轮&#xa;检查退出条件" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="275" y="250" width="140" height="170" as="geometry"/></mxCell>
        <mxCell id="p6-llm" value="LlmClient&#xa;DecisionService" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#1889A2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="520" y="150" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="p6-tools" value="ToolRegistry&#xa;工具路由" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#D9864F;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="520" y="260" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="p6-state" value="AgentState&#xa;StateStore" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#6F5CC2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="520" y="370" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="p6-stop" value="StopPolicy&#xa;重试与停止策略" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#44978C;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="520" y="480" width="180" height="66" as="geometry"/></mxCell>
        <mxCell id="p6-domain" value="Service / DAO&#xa;数据库与业务规则" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#D9864F;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="800" y="230" width="140" height="76" as="geometry"/></mxCell>
        <mxCell id="p6-external" value="HTTP Client / MCP&#xa;第三方接口" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#64748B;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p6-1"><mxGeometry x="800" y="390" width="140" height="76" as="geometry"/></mxCell>
        <mxCell id="p6-note" value="事务、身份权限、参数校验、异常处理和审计记录仍由后端系统负责" style="text;html=0;align=center;verticalAlign=middle;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" vertex="1" parent="p6-1"><mxGeometry x="250" y="630" width="500" height="36" as="geometry"/></mxCell>
        <mxCell id="p6-e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="p6-controller" target="p6-service" parent="p6-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p6-e2" value="启动" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p6-service" target="p6-runner" parent="p6-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p6-e3" value="决策" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p6-runner" target="p6-llm" parent="p6-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p6-e4" value="调用" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p6-runner" target="p6-tools" parent="p6-1"><mxGeometry relative="1" as="geometry"/></mxCell>
