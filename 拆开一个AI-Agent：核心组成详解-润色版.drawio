        <mxCell id="p2-e3" value="继续" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#94A3B8;labelBackgroundColor=#F7F9FC;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" edge="1" source="p2-state1" target="p2-llm2" parent="p2-1"><mxGeometry relative="1" as="geometry"/></mxCell>
