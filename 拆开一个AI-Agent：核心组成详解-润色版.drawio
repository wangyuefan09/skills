        <mxCell id="p4-0"/><mxCell id="p4-1" parent="p4-0"/>
        <mxCell id="p4-title" value="Agent 记忆的三个层次" style="text;html=0;align=center;verticalAlign=middle;resizable=0;points=[];fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=20;fontStyle=1;fontColor=#2D3748;" vertex="1" parent="p4-1"><mxGeometry x="300" y="24" width="400" height="40" as="geometry"/></mxCell>
        <mxCell id="p4-context" value="当前上下文" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#1889A2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="100" y="150" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="p4-context-save" value="保存&#xa;指令、输入、对话、工具结果" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#64748B;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="100" y="290" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-context-use" value="用途&#xa;提供给下一轮 LLM" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="100" y="440" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-state" value="任务状态" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#6F5CC2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="400" y="150" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="p4-state-save" value="保存&#xa;步骤、完成项、重试、等待状态" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#64748B;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="400" y="290" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-state-use" value="用途&#xa;控制执行、恢复和重试" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="400" y="440" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-long" value="长期记忆" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#44978C;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="700" y="150" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="p4-long-save" value="保存&#xa;用户偏好、配置、跨任务信息" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#64748B;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="700" y="290" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-long-use" value="用途&#xa;在后续会话中复用" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p4-1"><mxGeometry x="700" y="440" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="p4-note" value="三类记忆都需要控制保存范围、有效期、读取权限和删除方式" style="text;html=0;align=center;verticalAlign=middle;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontColor=#64748B;" vertex="1" parent="p4-1"><mxGeometry x="250" y="590" width="500" height="36" as="geometry"/></mxCell>
