        <mxCell id="p2-llm1" value="LLM 判断&#xa;先查询错误日志" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="60" y="150" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-tool1" value="工具执行&#xa;query_error_logs" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#D9864F;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="323" y="150" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-state1" value="写入记忆&#xa;缺少统计，继续" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#6F5CC2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="586" y="150" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-label2" value="第 2 轮：找出问题接口" style="text;html=0;align=left;verticalAlign=middle;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontStyle=1;fontColor=#2D3748;" vertex="1" parent="p2-1"><mxGeometry x="60" y="365" width="250" height="30" as="geometry"/></mxCell>
        <mxCell id="p2-llm2" value="LLM 判断&#xa;按接口聚合错误" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="60" y="410" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-tool2" value="工具执行&#xa;aggregate_errors" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#D9864F;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="323" y="410" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-state2" value="写入记忆&#xa;缺少发布信息，继续" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#6F5CC2;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="586" y="410" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-label3" value="第 3 轮：补齐关联证据" style="text;html=0;align=left;verticalAlign=middle;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;fontStyle=1;fontColor=#2D3748;" vertex="1" parent="p2-1"><mxGeometry x="60" y="625" width="250" height="30" as="geometry"/></mxCell>
        <mxCell id="p2-llm3" value="LLM 判断&#xa;查询服务发布记录" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#0B6170;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="60" y="670" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-tool3" value="工具执行&#xa;query_deployments" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#D9864F;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="323" y="670" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-state3" value="写入记忆&#xa;信息足够，结束" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#44978C;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="586" y="670" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="p2-result" value="返回分析结果&#xa;区分事实、关联可能和缺失证据" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#44978C;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, PingFang SC, Microsoft YaHei, sans-serif;fontSize=15;shadow=1;" vertex="1" parent="p2-1"><mxGeometry x="263" y="910" width="300" height="84" as="geometry"/></mxCell>
